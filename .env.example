# Optional: Gemini fallback for vision inference
GEMINI_API_KEY=

# Optional: ElevenLabs TTS when using `--voice elevenlabs`
ELEVENLABS_API_KEY=

# Optional: Forward each captured frame to AMD webhook so
# ElevenLabs `describe_scene` tool has live scene context.
# Example:
# WEBHOOK_UPLOAD_URL=http://165.245.140.111:8081/upload-frame
WEBHOOK_UPLOAD_URL=
